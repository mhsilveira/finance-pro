# MongoDB connection string
# When using Docker Compose, "mongo" is the service hostname
MONGODB_URI=mongodb://mongo:27017/financepro

# Backend API URL as seen by the browser (not container-to-container)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/dev

# Ollama AI (auto-configured in Docker, override for local dev)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
