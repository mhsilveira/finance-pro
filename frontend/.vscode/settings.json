{
	"editor.tabSize": 2,
	"editor.insertSpaces": true,
	"editor.detectIndentation": false,
	"files.eol": "\r\n",
	"editor.formatOnSave": true,
	"editor.defaultFormatter": "biomejs.biome",
	"editor.codeActionsOnSave": {
		"quickfix.biome": "explicit"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.tabSize": 2
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.tabSize": 2
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.tabSize": 2
	},
	"[javascriptreact]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.tabSize": 2
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.tabSize": 2
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.tabSize": 2
	}
}
